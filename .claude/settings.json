{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(pnpm tsc:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm drizzle-kit generate:*)",
      "Bash(pnpm drizzle-kit migrate:*)",
      "Bash(pnpm db:seed:*)",
      "Bash(pnpm dev:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(pnpm drizzle-kit push:*)",
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Write(./.env)",
      "Write(./.env.local)",
      "Write(./.env.production)",
      "Write(./dev.db)",
      "Write(./dev.db-journal)",
      "Write(./dev.db-shm)",
      "Write(./dev.db-wal)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/no-pg-core.js" },
          { "type": "command", "command": "node .claude/hooks/no-aschild-on-baseui.js" },
          { "type": "command", "command": "node .claude/hooks/no-prisma.js" },
          { "type": "command", "command": "node .claude/hooks/protect-secrets.js" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/hydration-check.js", "timeout": 30 }
        ]
      }
    ]
  }
}
